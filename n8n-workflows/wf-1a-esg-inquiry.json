      "id": "wf1a-0002",
      "name": "✅ 立即回應瀏覽器",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [420, 160]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nfunction mapBudget(budget) {\n  const map = {\n    'under10k': '1萬以下',\n    '10k-30k': '1–3萬',\n    '30k-50k': '3–5萬',\n    '50k-100k': '5–10萬',\n    'over100k': '10萬以上'\n  };\n  return map[budget] || '未提供';\n}\n\nfunction mapServiceType(type) {\n  const map = {\n    'esg-activity': 'ESG活動',\n    'gift': '永續禮品',\n    'both': '活動＋禮品',\n    'other': '其他'\n  };\n  return map[type] || 'ESG活動';\n}\n\nfunction mapSource(src) {\n  const map = {\n    'line-oa': 'LINE OA',\n    'referral': '轉介紹',\n    'social': '社群私訊',\n    'returning': '舊客回流'\n  };\n  return map[src] || '官網表單';\n}\n\nconst company = body.company || '未知企業';\nconst serviceType = mapServiceType(body.service_type);\nconst today = new Date().toISOString().split('T')[0];\nconst orderName = `${company}｜${serviceType}｜${today}`;\n\nconst notes = [\n  body.description ? `需求說明：${body.description}` : '',\n  body.event_location ? `活動地點：${body.event_location}` : '',\n  body.cooperation_type ? `合作形式：${body.cooperation_type}` : '',\n  body.esg_focus && body.esg_focus.length > 0 ? `ESG主題：${Array.isArray(body.esg_focus) ? body.esg_focus.join('、') : body.esg_focus}` : '',\n  body.esg_focus_note ? `補充方向：${body.esg_focus_note}` : '',\n  body.activity_goal ? `活動目標：${body.activity_goal}` : '',\n  body.esg_report ? `ESG報告需求：${body.esg_report}` : '',\n  body.report_usage && body.report_usage.length > 0 ? `報告用途：${Array.isArray(body.report_usage) ? body.report_usage.join('、') : body.report_usage}` : '',\n  body.source || body.form_source ? `來源管道：${body.source || body.form_source}` : ''\n].filter(Boolean).join('\\n');\n\nreturn [{\n  json: {\n    orderName,\n    orderType: serviceType,\n    headcount: body.headcount ? parseInt(body.headcount) : null,\n    budget: mapBudget(body.budget),\n    theme: body.description || '',\n    notes,\n    source: mapSource(body.form_source || body.source || ''),\n    eventDate: body.event_date || null,\n    company,\n    contactName: body.contact_name || '',\n    email: body.email || '',\n    phone: body.phone || ''\n  }\n}];"
      },
